{
  "manifest_version": 3,
  "name": "Replify",
  "version": "1.1",
  "description": "Replify Chrome Extension",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": [
    "storage",
    "clipboardWrite",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "http://127.0.0.1:8000/*"
  ]
}